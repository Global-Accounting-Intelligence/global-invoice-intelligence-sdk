{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Material",
  "type": "object",
  "required": [
    "material_id",
    "name"
  ],
  "properties": {
    "material_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supplier_references": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "barcodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "uoms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tax_category": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
