{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MaterialQualityReport",
  "type": "object",
  "required": [
    "score",
    "color",
    "issues",
    "recommendations"
  ],
  "properties": {
    "material_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "color": {
      "type": "string",
      "enum": [
        "green",
        "yellow",
        "orange",
        "red"
      ]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "duplicate_candidates": {
      "type": "array"
    }
  }
}
